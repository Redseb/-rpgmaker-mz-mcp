{
  "name": "rpgmaker-mz-mcp",
  "version": "1.0.0",
  "description": "High-quality MCP server for RPG Maker MZ integration - manage game data, maps, events, and plugins",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rpgmaker-mz-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:tools": "node scripts/sync-tool-count.mjs",
    "sync:tools:check": "node scripts/sync-tool-count.mjs --check",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "rpgmaker",
    "rpg-maker-mz",
    "game-development",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.5",
    "eslint": "^9.39.4",
    "prettier": "^3.9.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.7"
  }
}
